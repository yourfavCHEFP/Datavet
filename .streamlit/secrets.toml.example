# Optional credentials for richer source integrations.
# Copy to .streamlit/secrets.toml and fill values when deploying.

[kaggle]
username = "YOUR_KAGGLE_USERNAME"
key = "YOUR_KAGGLE_API_KEY"

# Optional proxy services that return JSON like: { "datasets": ["title1", "title2"] }
gemini_proxy = "https://your-api.example.com/gemini-datasets"
kimi_proxy = "https://your-api.example.com/kimi-datasets"

# Additional provider keys can be added here in future as new connectors are introduced.
